{
  "appId": "com.zencalendar.app",
  "appName": "ZenCalendar",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "backgroundColor": "#09090f",
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#09090f",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    }
  }
}
